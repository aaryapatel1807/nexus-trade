# Backend Environment Variables
# Copy this file to .env and fill in your values

# Required - PostgreSQL connection string (auto-provided by Railway)
DATABASE_URL="postgresql://user:password@host:5432/db"

# Required - Secret key for JWT token signing (make this a long random string)
JWT_SECRET="your_super_secret_jwt_key_here"

# Required - Google Gemini API key (for AI Advisor)
GEMINI_API_KEY="your_gemini_api_key_here"

# Optional - Finnhub API key (for real-time stock quotes)
FINNHUB_API_KEY="your_finnhub_api_key_here"

# Optional - Port (Railway auto-sets this)
PORT=5000
